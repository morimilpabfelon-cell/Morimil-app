{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://morimil.app/schemas/keystore_gate.phase5a.schema.json",
  "title": "Morimil App Phase 5A Keystore Credential Gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "phase",
    "keystore_enabled",
    "hardcoded_token_allowed",
    "network_permission_enabled",
    "github_api_calls_enabled",
    "github_write_enabled",
    "pc_execution_enabled"
  ],
  "properties": {
    "phase": {
      "const": "phase_5a"
    },
    "keystore_enabled": {
      "const": true
    },
    "hardcoded_token_allowed": {
      "const": false
    },
    "network_permission_enabled": {
      "const": false
    },
    "github_api_calls_enabled": {
      "const": false
    },
    "github_write_enabled": {
      "const": false
    },
    "pc_execution_enabled": {
      "const": false
    }
  }
}
