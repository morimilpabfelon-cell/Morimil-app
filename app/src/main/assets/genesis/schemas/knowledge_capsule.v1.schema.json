{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://morimil.local/schemas/knowledge_capsule.v1.schema.json",
  "title": "Morimil Knowledge Capsule v1",
  "type": "object",
  "required": [
    "schema_version",
    "capsule_id",
    "instance_id",
    "genesis_core_hash",
    "source",
    "learning",
    "application",
    "privacy",
    "audit",
    "migration"
  ],
  "properties": {
    "schema_version": { "const": "morimil.knowledge_capsule.v1" },
    "capsule_id": { "type": "string", "pattern": "^know_[0-9]{6,}$" },
    "instance_id": { "type": "string", "minLength": 1 },
    "genesis_core_hash": { "type": "string", "pattern": "^sha256:.+" },
    "source": {
      "type": "object",
      "required": ["type", "title", "author", "locator", "retrieved_at"],
      "properties": {
        "type": { "type": "string", "enum": ["book", "paper", "documentation", "repository", "conversation", "course", "manual"] },
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": ["string", "null"] },
        "locator": { "type": ["string", "null"] },
        "retrieved_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "learning": {
      "type": "object",
      "required": ["summary", "concepts", "principles", "confidence", "limitations"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "concepts": { "type": "array", "items": { "type": "string" } },
        "principles": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "limitations": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "application": {
      "type": "object",
      "required": ["applies_to", "project_bindings", "skill_bindings", "requires_self_update_proposal"],
      "properties": {
        "applies_to": { "type": "array", "items": { "type": "string" } },
        "project_bindings": { "type": "array", "items": { "type": "string" } },
        "skill_bindings": { "type": "array", "items": { "type": "string" } },
        "requires_self_update_proposal": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": ["visibility", "copyright_sensitive", "export_allowed"],
      "properties": {
        "visibility": { "type": "string", "enum": ["private_local", "user_exportable", "shareable_summary"] },
        "copyright_sensitive": { "type": "boolean" },
        "export_allowed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "audit": {
      "type": "object",
      "required": ["created_by", "created_at", "source_memory_event_id"],
      "properties": {
        "created_by": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" },
        "source_memory_event_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "migration": {
      "type": "object",
      "required": ["created_schema_version", "current_schema_version", "migration_history"],
      "properties": {
        "created_schema_version": { "const": "morimil.knowledge_capsule.v1" },
        "current_schema_version": { "type": "string", "minLength": 1 },
        "migration_history": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
